@model Shopix.Models.Classes.Product

@{
    ViewBag.Title = "AddProduct";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<form class="form-group" method="post">
    @Html.AntiForgeryToken()
    @Html.LabelFor(x => x.ProductName)
    @Html.TextBoxFor(x => x.ProductName, new { @class = "form-control" })
    <br>
    @Html.LabelFor(x => x.Brand)
    @Html.TextBoxFor(x => x.Brand, new { @class = "form-control" })
    <br>
    @Html.LabelFor(x => x.Stock)
    @Html.TextBoxFor(x => x.Stock, new { @class = "form-control" })
    <br>
    @Html.LabelFor(x => x.BuyingPrice)
    @Html.TextBoxFor(x => x.BuyingPrice, new { @class = "form-control" })
    <br>
    @Html.LabelFor(x => x.SellingPrice)
    @Html.TextBoxFor(x => x.SellingPrice, new { @class = "form-control" })
    <br>
    @Html.LabelFor(x => x.Category.CategoryId)
    @Html.DropDownListFor(x => x.CategoryId, (List<SelectListItem>)ViewBag.value, new { @class = "form-control" })
    @*@Html.TextBoxFor(x => x.CategoryId, new { @class = "form-control" })*@
    <br>
    @Html.LabelFor(x => x.ProductImage)
    @Html.TextBoxFor(x => x.ProductImage, new { @class = "form-control" })
    <br>
    @Html.LabelFor(x => x.Status)
    @Html.TextBoxFor(x => x.Status, new { @class = "form-control" })
    <br>

    <button class="btn btn-primary">Add</button>
</form>


